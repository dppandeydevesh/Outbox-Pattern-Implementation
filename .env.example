# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/outbox_demo

# ─── Outbox Publisher ─────────────────────────────────────────────────────────
# How often the publisher polls for pending entries (milliseconds)
OUTBOX_POLL_INTERVAL_MS=5000
# How many entries to process per poll cycle
OUTBOX_BATCH_SIZE=10

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to 'true' to simulate random broker failures (testing only)
SIMULATE_FAILURES=false

# ─── Shell Script Thresholds ─────────────────────────────────────────────────
MAX_PENDING_ALERT=100
MAX_FAILED_ALERT=10
API_URL=http://localhost:3000
